---
layout: layouts/base.njk
permalink: /contact.html
title: Contact
description: Contact Arsalan Iftikhar for career and professional enquiries or NexAura consulting enquiries.
canonicalPath: /contact.html
---
<section class="page-intro section">
  <p class="eyebrow">{{ profile.locationLine }}</p>
  <h1>Contact</h1>
  <p class="lede">Based in West Yorkshire, UK, and open to relocation.</p>
</section>

<section class="section contact-grid" aria-label="Contact options">
  <article class="contact-card panel" id="career" aria-labelledby="career-heading">
    <div class="content-stack">
      <h2 id="career-heading">Career and professional enquiries</h2>
      <p>For roles, interviews or professional conversations, email me or connect on LinkedIn.</p>
    </div>
    <div class="contact-card__links">
      <a href="{{ contacts.career.href }}">{{ contacts.career.email }}</a>
      <a href="{{ contacts.linkedin.url }}" target="_blank" rel="noopener noreferrer">{{ contacts.linkedin.label }}</a>
    </div>
    <div class="actions">
      <a class="button" href="{{ cv.url }}" download>{{ cv.label }}</a>
    </div>
  </article>

  <article class="contact-card panel" id="consulting" aria-labelledby="consulting-heading">
    <div class="content-stack">
      <h2 id="consulting-heading">NexAura consulting enquiries</h2>
      <p>For business intelligence, automation and data-product consulting, use my NexAura email.</p>
    </div>
    <div class="contact-card__links">
      <a href="{{ contacts.consulting.href }}">{{ contacts.consulting.email }}</a>
    </div>
  </article>
</section>
