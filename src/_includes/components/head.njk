{% set rawTitle = title or site.name %}
{% if rawTitle == site.name %}
  {% set fullTitle = rawTitle %}
{% else %}
  {% set fullTitle = seo.titlePattern | replace("%s", rawTitle) %}
{% endif %}
{% set metaDescription = description or seo.defaultDescription %}
{% set canonicalTarget = canonicalPath or page.url %}
{% set canonicalUrl = seo.baseCanonicalUrl + canonicalTarget %}
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <title>{{ fullTitle }}</title>
  <meta name="description" content="{{ metaDescription }}">
  <link rel="canonical" href="{{ canonicalUrl }}">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%2307111f'/%3E%3Cpath d='M16 43V21M16 43h33M23 38l8-8 6 5 10-13' fill='none' stroke='%2322d3ee' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E">
  <meta property="og:type" content="{{ seo.defaultOpenGraphType }}">
  <meta property="og:title" content="{{ fullTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <script>
    (function () {
      var root = document.documentElement;
      var key = "portfolio-theme";
      var stored = null;
      root.classList.add("js");
      try {
        stored = window.localStorage.getItem(key);
      } catch (error) {}
      var theme = stored === "dark" || stored === "light"
        ? stored
        : window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      root.setAttribute("data-theme", theme);
      root.style.colorScheme = theme;
    })();
  </script>
  <link rel="stylesheet" href="/assets/css/portfolio.css">
  <script src="/assets/js/theme.js" defer></script>
  <script src="/assets/js/navigation.js" defer></script>
</head>
