  {% elif iconName == "contact" %}
    <path d="M4.75 6.5h14.5v11H4.75z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="m5.25 7 6.75 5.2L18.75 7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  {% else %}
    <path d="M5 18.5V5.5M5 18.5h14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
    <path d="m7.5 15 3.2-3.1 2.3 1.8 4.4-5.2" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
