    <path d="M9.5 9.5h2.25c1.1 0 2 .9 2 2v3h.75" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M5 16.5h4.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
  {% elif iconName == "automation" %}
    <path d="M7.2 8.2A6 6 0 0 1 17.8 7l1.05 1.05M16.8 15.8A6 6 0 0 1 6.2 17l-1.05-1.05" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M18.85 4.85v3.2h-3.2M5.15 19.15v-3.2h3.2" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
  {% elif iconName == "cloud" %}
